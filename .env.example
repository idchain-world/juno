# OpenRouter API key (required). Sign up at https://openrouter.ai to get one.
OPENROUTER_API_KEY=

# OpenRouter model slug (required). Examples:
#   anthropic/claude-3.5-sonnet
#   openai/gpt-4o-mini
#   meta-llama/llama-3.1-70b-instruct
OPENROUTER_MODEL=openai/gpt-4o-mini

# Port the HTTP server binds to inside the container.
# docker-compose publishes this same port on the host.
PUBLIC_AGENT_PORT=4200

# Display name this agent advertises in SKILL.md and the REST-AP catalog.
PUBLIC_AGENT_NAME=public-agent

# Optional shared secret. If set, clients must send
#   Authorization: Bearer <key>
# on every request. If unset, every endpoint is open.
PUBLIC_AGENT_AUTH_KEY=

# Daily OpenRouter token budget (prompt + completion summed). When exceeded,
# POST /talk returns 503 until UTC midnight. 0 disables the ceiling.
MAX_TOKENS_PER_DAY=100000

# Per-IP rate limit for POST /talk (requests per minute). 0 disables.
TALK_RATE_LIMIT_PER_MIN=10
