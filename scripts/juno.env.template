# Juno per-instance environment template.
#
# Rendered by scripts/juno-add.sh to /etc/juno/<name>.env (chmod 0600).
# Do not place this template into /etc/juno/ directly — the add-script
# fills in the instance-specific lines marked __PLACEHOLDER__.
#
# Each juno instance gets its own file. One field per line. No quoting.

# ── Rendered by juno-add.sh ──────────────────────────────────────────────
PUBLIC_AGENT_NAME=__NAME__
PUBLIC_URL=https://__DOMAIN__
PUBLIC_AGENT_HOST=127.0.0.1
PUBLIC_AGENT_PORT=__PUBLIC_PORT__
OPERATOR_HOST=127.0.0.1
OPERATOR_PORT=__OPERATOR_PORT__
PUBLIC_AGENT_DATA_DIR=/opt/juno/instances/__NAME__/data
PUBLIC_AGENT_KNOWLEDGE_DIR=/opt/juno/instances/__NAME__/knowledge
PUBLIC_AGENT_AUTH_KEY=__AUTH_KEY__

# ── Operator MUST fill in ────────────────────────────────────────────────
# Use a per-instance OpenRouter key for accurate attribution and blast-radius
# isolation. Do not share one key across instances.
OPENROUTER_API_KEY=__OPENROUTER_API_KEY__
OPENROUTER_MODEL=google/gemini-2.5-flash

# ── Budget / rate limits (per instance) ──────────────────────────────────
# Do not leave these unset. One instance's runaway spend should not be able
# to burn the whole VPS's OpenRouter balance. The values below are safe
# defaults; raise them deliberately per instance.
MAX_TOKENS_PER_DAY=100000
TALK_RATE_LIMIT_PER_MIN=20
MAX_REPLY_TOKENS=1024
MAX_MESSAGE_CHARS=4000
MAX_TURNS_PER_SESSION=40
SESSION_IDLE_MINUTES=30

# ── Caddy/reverse-proxy trust ────────────────────────────────────────────
TRUSTED_PROXY=true
