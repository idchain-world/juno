# Juno environment — copy to /etc/juno.env on the VPS, chmod 600 root:juno.
# All values shown with bracketed placeholders must be filled in.

# ── Required ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=[paste-your-openrouter-key-here]
OPENROUTER_MODEL=google/gemini-2.5-flash
PUBLIC_AGENT_AUTH_KEY=[run `openssl rand -hex 32` and paste the result]
PUBLIC_URL=https://docs.idagents.ai
PUBLIC_AGENT_NAME=docs-idagents

# ── Public surface (internet-facing via Caddy reverse proxy) ─────────────
PUBLIC_AGENT_HOST=127.0.0.1
PUBLIC_AGENT_PORT=4200

# ── Operator surface (loopback only; reach via SSH tunnel) ───────────────
OPERATOR_HOST=127.0.0.1
OPERATOR_PORT=4201

# ── Storage ──────────────────────────────────────────────────────────────
PUBLIC_AGENT_DATA_DIR=/opt/juno/data
PUBLIC_AGENT_KNOWLEDGE_DIR=/opt/juno/knowledge

# ── Budget / rate limits ─────────────────────────────────────────────────
# MAX_TOKENS_PER_DAY=100000           # 0 or unset = no daily cap
# TALK_RATE_LIMIT_PER_MIN=20
# MAX_MESSAGE_CHARS=4000
# MAX_REPLY_TOKENS=1024
# MAX_TURNS_PER_SESSION=40
# SESSION_IDLE_MINUTES=30

# ── Caddy/reverse-proxy trust ────────────────────────────────────────────
TRUSTED_PROXY=true
