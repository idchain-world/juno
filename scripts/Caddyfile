# Replace docs.idagents.ai with your actual hostname.
#
# Only the PUBLIC endpoints are proxied. Operator endpoints
# (/inbox, /news, /mcp) stay on 127.0.0.1:4201 and are reached
# from your laptop via:
#   ssh -L 4201:127.0.0.1:4201 root@<vps-ip>

docs.idagents.ai {
    encode gzip

    reverse_proxy 127.0.0.1:4200

    # Belt-and-suspenders: even if PUBLIC_AGENT_HOST gets misconfigured,
    # we refuse operator-only paths from the public interface. /mcp and
    # /news are intentionally NOT in this list — both are exposed publicly
    # on the public Hono listener. /news enforces session scoping itself
    # (session_id required; callers only see their own items), and /mcp
    # exposes only the `talk` tool. Only the operator /inbox stays 404 here.
    @operator path /inbox*
    respond @operator 404

    log {
        output file /var/log/caddy/juno.log {
            roll_size 50mb
            roll_keep 5
        }
        format console
    }
}
